---
// XO Diamonds – Footer
// Minimal luxury footer with gold accent.
const base = import.meta.env.BASE_URL;
---

<footer class="bg-black text-white">
  <div class="container py-16 md:py-20">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 md:gap-8">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href={`${base}`} class="inline-flex flex-col">
          <span class="font-serif text-2xl tracking-[0.08em] text-white leading-none">XO</span>
          <span class="text-[0.5rem] tracking-[0.3em] uppercase text-gray-400 mt-1">Diamonds</span>
        </a>
        <p class="text-gray-400 text-sm mt-6 leading-relaxed max-w-xs">
          Ювелирные украшения<br />с CVD бриллиантами.<br />Лабораторная чистота,<br />природная красота.
        </p>
      </div>

      <!-- Catalog -->
      <div>
        <h4 class="text-xs tracking-[0.15em] uppercase text-gray-300 mb-6">Каталог</h4>
        <ul class="space-y-3 text-sm text-gray-400">
          <li><a href={`${base}catalog/`} class="hover:text-white transition-colors">Все изделия</a></li>
          <li><a href={`${base}catalog/?category=rings`} class="hover:text-white transition-colors">Кольца</a></li>
          <li><a href={`${base}catalog/?category=earrings`} class="hover:text-white transition-colors">Серьги</a></li>
          <li><a href={`${base}catalog/?category=pendants`} class="hover:text-white transition-colors">Подвески</a></li>
          <li><a href={`${base}catalog/?category=bracelets`} class="hover:text-white transition-colors">Браслеты</a></li>
        </ul>
      </div>

      <!-- Info -->
      <div>
        <h4 class="text-xs tracking-[0.15em] uppercase text-gray-300 mb-6">Информация</h4>
        <ul class="space-y-3 text-sm text-gray-400">
          <li><a href={`${base}about/`} class="hover:text-white transition-colors">О бренде</a></li>
          <li><a href={`${base}delivery/`} class="hover:text-white transition-colors">Доставка и оплата</a></li>
          <li><a href={`${base}faq/`} class="hover:text-white transition-colors">FAQ</a></li>
          <li><a href={`${base}guide/cvd-diamonds/`} class="hover:text-white transition-colors">Гид по CVD</a></li>
          <li><a href={`${base}contacts/`} class="hover:text-white transition-colors">Контакты</a></li>
        </ul>
      </div>

      <!-- Contacts -->
      <div>
        <h4 class="text-xs tracking-[0.15em] uppercase text-gray-300 mb-6">Связь</h4>
        <ul class="space-y-3 text-sm text-gray-400">
          <li>
            <a href="https://t.me/xodiamondss" target="_blank" rel="noopener" class="hover:text-white transition-colors inline-flex items-center gap-2">
              <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.562 8.161c-.18 1.897-.962 6.502-1.359 8.627-.168.9-.5 1.201-.82 1.23-.697.064-1.226-.46-1.901-.903-1.056-.692-1.653-1.123-2.678-1.799-1.185-.781-.417-1.21.258-1.911.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.329-.913.489-1.302.481-.428-.009-1.252-.242-1.865-.441-.752-.244-1.349-.374-1.297-.79.027-.216.324-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635.099-.002.321.023.465.141.119.098.152.228.168.32.016.093.037.307.021.473z"/></svg>
              Telegram
            </a>
          </li>
          <li>
            <a href="https://instagram.com/xo_diamonds" target="_blank" rel="noopener" class="hover:text-white transition-colors inline-flex items-center gap-2">
              <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
              Instagram
            </a>
          </li>
          <li>
            <a href="https://wa.me/" target="_blank" rel="noopener" class="hover:text-white transition-colors inline-flex items-center gap-2">
              <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              WhatsApp
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-gray-800 mt-12 pt-8 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-gray-500">
      <span>&copy; {new Date().getFullYear()} XO Diamonds. Все права защищены.</span>
      <span>Лабораторно выращенные бриллианты CVD</span>
    </div>
  </div>
</footer>
