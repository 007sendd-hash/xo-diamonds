---
// XO Diamonds – Header
// Fixed top nav: minimal luxury with logo center.
---

<header
  class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md border-b border-gray-100"
  x-data="{ open: false }"
>
  <nav class="container flex items-center justify-between h-16 md:h-20">
    <!-- Mobile hamburger -->
    <button
      class="md:hidden p-2 -ml-2"
      @click="open = !open"
      aria-label="Меню"
    >
      <span class="block w-5 h-px bg-black" :class="{ 'rotate-45 translate-y-1.5': open }"></span>
      <span class="block w-5 h-px bg-black mt-1.5" :class="{ 'opacity-0': open }"></span>
      <span class="block w-5 h-px bg-black mt-1.5" :class="{ '-rotate-45 -translate-y-1.5': open }"></span>
    </button>

    <!-- Desktop nav – left links -->
    <div class="hidden md:flex items-center gap-8 text-xs tracking-[0.12em] uppercase text-gray-600">
      <a href="/catalog/" class="hover:text-black transition-colors">Каталог</a>
      <a href="/collections/" class="hover:text-black transition-colors">Коллекции</a>
      <a href="/about/" class="hover:text-black transition-colors">О бренде</a>
    </div>

    <!-- Logo – center -->
    <a href="/" class="absolute left-1/2 -translate-x-1/2 flex flex-col items-center">
      <span class="font-serif text-xl md:text-2xl tracking-[0.08em] text-black leading-none">XO</span>
      <span class="text-[0.5rem] tracking-[0.3em] uppercase text-gray-400 mt-1">Diamonds</span>
    </a>

    <!-- Desktop nav – right links -->
    <div class="hidden md:flex items-center gap-8 text-xs tracking-[0.12em] uppercase text-gray-600">
      <a href="/about/" class="hover:text-black transition-colors">История</a>
      <a href="/contacts/" class="hover:text-black transition-colors">Контакты</a>
      <!-- Cart icon -->
      <a
        href="/cart/"
        class="relative hover:text-black transition-colors"
        x-data="{ count: 0 }"
        x-init="
          count = JSON.parse(localStorage.getItem('xo-cart') || '[]').reduce((s,i) => s + i.qty, 0);
          window.addEventListener('cart-updated', () => {
            count = JSON.parse(localStorage.getItem('xo-cart') || '[]').reduce((s,i) => s + i.qty, 0);
          });
        "
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M2 2h2l1.5 8h7l1.5-5H4" />
          <circle cx="5.5" cy="13.5" r="1" />
          <circle cx="12.5" cy="13.5" r="1" />
        </svg>
        <span
          x-show="count > 0"
          x-text="count"
          class="absolute -top-2 -right-2 text-[0.6rem] bg-black text-white w-4 h-4 rounded-full flex items-center justify-center font-medium"
        ></span>
      </a>
    </div>

    <!-- Mobile cart -->
    <a
      href="/cart/"
      class="md:hidden relative p-2"
      x-data="{ count: 0 }"
      x-init="
        count = JSON.parse(localStorage.getItem('xo-cart') || '[]').reduce((s,i) => s + i.qty, 0);
        window.addEventListener('cart-updated', () => {
          count = JSON.parse(localStorage.getItem('xo-cart') || '[]').reduce((s,i) => s + i.qty, 0);
        });
      "
    >
      <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M2 2h2l1.5 8h7l1.5-5H4" />
        <circle cx="5.5" cy="13.5" r="1" />
        <circle cx="12.5" cy="13.5" r="1" />
      </svg>
      <span
        x-show="count > 0"
        x-text="count"
        class="absolute -top-1 -right-1 text-[0.6rem] bg-black text-white w-4 h-4 rounded-full flex items-center justify-center font-medium"
      ></span>
    </a>
  </nav>

  <!-- Mobile menu -->
  <nav
    x-show="open"
    x-transition.opacity
    class="md:hidden bg-white border-t border-gray-100 pb-6"
    @click.away="open = false"
  >
    <div class="container flex flex-col gap-4 text-sm tracking-[0.1em] uppercase pt-4">
      <a href="/catalog/" class="block py-1" @click="open = false">Каталог</a>
      <a href="/collections/" class="block py-1" @click="open = false">Коллекции</a>
      <a href="/about/" class="block py-1" @click="open = false">О бренде</a>
      <a href="/delivery/" class="block py-1" @click="open = false">Доставка</a>
      <a href="/contacts/" class="block py-1" @click="open = false">Контакты</a>
    </div>
  </nav>
</header>

<!-- Spacer for fixed header -->
<div class="h-16 md:h-20"></div>

<script is:inline>
  // Cart badge sync helper
  document.addEventListener("DOMContentLoaded", () => {
    const updateCartBadge = () => {
      window.dispatchEvent(new CustomEvent("cart-updated"));
    };
    window.addEventListener("storage", updateCartBadge);
  });
</script>
