---
// XO Diamonds – 404 Page
import Base from "../layouts/Base.astro";
const base = import.meta.env.BASE_URL;
---

<Base title="Страница не найдена" description="Страница не найдена. Вернитесь на главную или в каталог XO Diamonds." noIndex>
  <section class="section flex items-center justify-center min-h-[60vh]">
    <div class="container text-center max-w-lg">
      <span class="gold-line centered"></span>
      <h1 class="text-6xl md:text-8xl font-serif mb-4">404</h1>
      <p class="text-gray-500 mb-8">
        Страница, которую вы ищете, не существует или была перемещена.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href={`${base}`} class="btn btn-primary">На главную</a>
        <a href={`${base}catalog/`} class="btn btn-outline">В каталог</a>
      </div>
    </div>
  </section>
</Base>
