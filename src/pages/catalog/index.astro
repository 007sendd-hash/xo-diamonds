---
// XO Diamonds – Catalog Page
// Full product grid with filters.
import Base from "../../layouts/Base.astro";

const pageTitle = "Каталог украшений";
const pageDescription = "Каталог ювелирных украшений XO Diamonds с CVD бриллиантами. Кольца, серьги, подвески, браслеты из золота 585 пробы.";
---

<Base title={pageTitle} description={pageDescription}>
  <!-- Header -->
  <section class="section-sm">
    <div class="container">
      <span class="gold-line"></span>
      <h1 class="mb-4">Каталог</h1>
      <p class="text-gray-500 max-w-lg">
        Ювелирные украшения с лабораторно выращенными бриллиантами CVD.
        Каждое изделие создано вручную из золота 585 пробы.
      </p>
    </div>
  </section>

  <!-- Catalog Grid -->
  <section
    class="section-sm pb-20"
    x-data="{
      category: 'all',
      sort: 'default',
      products: [
        {
          slug: 'ring-solitaire-cvd-1-5ct',
          title: 'Кольцо Solitaire CVD 1.5ct',
          price: 185000,
          category: 'кольца',
          isNew: true,
          image: '/images/products/ring-solitaire-1.jpg'
        },
        {
          slug: 'earrings-cvd-stud-0-8ct',
          title: 'Серьги-пусеты CVD 0.8ct',
          price: 120000,
          category: 'серьги',
          isNew: true,
          image: '/images/products/earrings-stud-1.jpg'
        },
        {
          slug: 'pendant-cvd-cross-1ct',
          title: 'Подвеска Cross CVD 1ct',
          price: 95000,
          category: 'подвески',
          isNew: false,
          image: '/images/products/pendant-cross-1.jpg'
        },
        {
          slug: 'bracelet-tennis-cvd-2ct',
          title: 'Браслет Tennis CVD 2ct',
          price: 250000,
          category: 'браслеты',
          isNew: false,
          image: '/images/products/bracelet-tennis-1.jpg'
        },
        {
          slug: 'ring-eternity-cvd-1ct',
          title: 'Кольцо Eternity CVD 1ct',
          price: 165000,
          category: 'кольца',
          isNew: false,
          image: '/images/products/ring-eternity-1.jpg'
        },
        {
          slug: 'earrings-drop-cvd-1-2ct',
          title: 'Серьги Drop CVD 1.2ct',
          price: 145000,
          category: 'серьги',
          isNew: false,
          image: '/images/products/earrings-drop-1.jpg'
        }
      ],
      get filtered() {
        let items = this.products;
        if (this.category !== 'all') {
          items = items.filter(p => p.category === this.category);
        }
        if (this.sort === 'price-asc') {
          items = items.slice().sort((a, b) => a.price - b.price);
        } else if (this.sort === 'price-desc') {
          items = items.slice().sort((a, b) => b.price - a.price);
        }
        return items;
      },
      formatPrice(n) {
        return new Intl.NumberFormat('ru-RU').format(n) + ' ₽';
      }
    }"
  >
    <div class="container">
      <!-- Filters -->
      <div class="flex flex-wrap items-center gap-4 mb-10 pb-6 border-b border-gray-100">
        <span class="text-xs tracking-[0.15em] uppercase text-gray-400">Фильтр:</span>
        <div class="flex flex-wrap gap-2">
          {[
            { value: "all", label: "Все" },
            { value: "кольца", label: "Кольца" },
            { value: "серьги", label: "Серьги" },
            { value: "подвески", label: "Подвески" },
            { value: "браслеты", label: "Браслеты" },
          ].map((f) => (
            <button
              class="text-xs tracking-[0.08em] uppercase px-4 py-1.5 border transition-colors"
              :class="category === '{f.value}' ? 'border-black bg-black text-white' : 'border-gray-200 hover:border-black text-gray-600'"
              @click={`category = '${f.value}'`}
            >
              {f.label}
            </button>
          ))}
        </div>

        <span class="ml-auto text-xs tracking-[0.15em] uppercase text-gray-400">Сортировка:</span>
        <select
          x-model="sort"
          class="text-sm border border-gray-200 px-3 py-1.5 bg-white focus:outline-none focus:border-black"
        >
          <option value="default">По умолчанию</option>
          <option value="price-asc">По возрастанию цены</option>
          <option value="price-desc">По убыванию цены</option>
        </select>
      </div>

      <!-- Grid -->
      <div class="grid-3">
        <template x-for="p in filtered" :key="p.slug">
          <div class="product-card group">
            <a :href="`/catalog/${p.slug}/`" class="block">
              <div class="img-zoom relative bg-gray-100">
                <img
                  :src="p.image"
                  :alt="p.title"
                  width="600"
                  height="800"
                  class="w-full aspect-[3/4] object-cover"
                />
                <span
                  x-show="p.isNew"
                  class="absolute top-3 left-3 bg-black text-white text-[0.625rem] tracking-[0.15em] uppercase px-2 py-0.5"
                >
                  Новинка
                </span>
              </div>
              <div class="mt-4">
                <span class="text-[0.625rem] tracking-[0.15em] uppercase text-gray-400" x-text="p.category"></span>
                <h3 class="text-lg font-serif mt-1" x-text="p.title"></h3>
                <p class="text-sm text-gray-600 mt-1" x-text="formatPrice(p.price)"></p>
              </div>
            </a>
          </div>
        </template>
      </div>

      <!-- Empty state -->
      <div x-show="filtered.length === 0" class="text-center py-20">
        <p class="text-gray-400">Товары не найдены</p>
      </div>
    </div>
  </section>
</Base>
