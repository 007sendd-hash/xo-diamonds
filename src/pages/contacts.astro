---
// XO Diamonds – Contacts Page
import Base from "../layouts/Base.astro";

const pageTitle = "Контакты";
const pageDescription = "Свяжитесь с XO Diamonds. Instagram, Telegram, WhatsApp. Консультация по выбору ювелирных украшений с CVD бриллиантами.";
---

<Base title={pageTitle} description={pageDescription}>
  <section class="section-sm">
    <div class="container max-w-2xl">
      <span class="gold-line"></span>
      <h1 class="mb-4">Контакты</h1>
      <p class="text-gray-500 mb-12">
        Мы на связи в удобных для вас мессенджерах. Выберите способ связи или
        оставьте сообщение через форму.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
        <!-- Telegram -->
        <a
          href="https://t.me/xodiamondss"
          target="_blank"
          rel="noopener"
          class="block bg-gray-50 p-8 text-center hover:bg-gray-100 transition-colors group"
        >
          <div class="w-12 h-12 mx-auto mb-4 flex items-center justify-center">
            <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24" class="text-black group-hover:text-[#c4a65a] transition-colors">
              <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.562 8.161c-.18 1.897-.962 6.502-1.359 8.627-.168.9-.5 1.201-.82 1.23-.697.064-1.226-.46-1.901-.903-1.056-.692-1.653-1.123-2.678-1.799-1.185-.781-.417-1.21.258-1.911.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.329-.913.489-1.302.481-.428-.009-1.252-.242-1.865-.441-.752-.244-1.349-.374-1.297-.79.027-.216.324-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635.099-.002.321.023.465.141.119.098.152.228.168.32.016.093.037.307.021.473z"/>
            </svg>
          </div>
          <h4 class="text-sm tracking-[0.1em] uppercase mb-1">Telegram</h4>
          <p class="text-xs text-gray-400">@xodiamondss</p>
        </a>

        <!-- Instagram -->
        <a
          href="https://instagram.com/xo_diamonds"
          target="_blank"
          rel="noopener"
          class="block bg-gray-50 p-8 text-center hover:bg-gray-100 transition-colors group"
        >
          <div class="w-12 h-12 mx-auto mb-4 flex items-center justify-center">
            <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24" class="text-black group-hover:text-[#c4a65a] transition-colors">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </div>
          <h4 class="text-sm tracking-[0.1em] uppercase mb-1">Instagram</h4>
          <p class="text-xs text-gray-400">@xo_diamonds</p>
        </a>

        <!-- WhatsApp -->
        <a
          href="https://wa.me/"
          target="_blank"
          rel="noopener"
          class="block bg-gray-50 p-8 text-center hover:bg-gray-100 transition-colors group"
        >
          <div class="w-12 h-12 mx-auto mb-4 flex items-center justify-center">
            <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24" class="text-black group-hover:text-[#c4a65a] transition-colors">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347"/>
            </svg>
          </div>
          <h4 class="text-sm tracking-[0.1em] uppercase mb-1">WhatsApp</h4>
          <p class="text-xs text-gray-400">Написать</p>
        </a>
      </div>

      <!-- Contact form -->
      <div class="bg-gray-50 p-8 md:p-12">
        <h3 class="mb-6">Отправить сообщение</h3>
        <form class="space-y-5" x-data="{ sent: false }" @submit.prevent="sent = true">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
              <label class="block text-xs tracking-[0.08em] uppercase text-gray-500 mb-1.5">Имя</label>
              <input
                type="text"
                class="w-full border border-gray-200 bg-white px-4 py-3 text-sm focus:outline-none focus:border-black transition-colors"
                placeholder="Ваше имя"
              />
            </div>
            <div>
              <label class="block text-xs tracking-[0.08em] uppercase text-gray-500 mb-1.5">Email или телефон</label>
              <input
                type="text"
                class="w-full border border-gray-200 bg-white px-4 py-3 text-sm focus:outline-none focus:border-black transition-colors"
                placeholder="email@example.com"
              />
            </div>
          </div>
          <div>
            <label class="block text-xs tracking-[0.08em] uppercase text-gray-500 mb-1.5">Сообщение</label>
            <textarea
              rows="4"
              class="w-full border border-gray-200 bg-white px-4 py-3 text-sm focus:outline-none focus:border-black transition-colors resize-none"
              placeholder="Ваше сообщение..."
            ></textarea>
          </div>
          <button type="submit" class="btn btn-primary">
            Отправить
          </button>
          <p x-show="sent" class="text-sm text-green-700 mt-2" x-cloak>
            ✓ Сообщение отправлено. Мы ответим в ближайшее время.
          </p>
        </form>
      </div>
    </div>
  </section>
</Base>
