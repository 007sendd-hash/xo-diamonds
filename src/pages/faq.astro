---
// XO Diamonds – FAQ Page
import Base from "../layouts/Base.astro";

const pageTitle = "Часто задаваемые вопросы";
const pageDescription = "Ответы на самые часто задаваемые вопросы о CVD бриллиантах и украшениях XO Diamonds.";

const faqs = [
  {
    q: "Чем CVD бриллианты отличаются от природных?",
    a: "По химическому составу и оптическим свойствам — ничем. CVD бриллиант — это настоящий алмаз, идентичный природному. Единственное отличие — происхождение: CVD бриллианты выращиваются в лабораторных условиях, а не добываются из земли. Это делает их на 100% бесконфликтными и экологичными.",
  },
  {
    q: "CVD бриллианты дешевле природных?",
    a: "Да, CVD бриллианты на 60–70% доступнее природных аналогов при идентичных характеристиках. Причина — более эффективный процесс производства и отсутствие монополии на добычу. Вы платите за качество и красоту камня, а не за его историю.",
  },
  {
    q: "Из какого металла изготовлены украшения?",
    a: "Все изделия XO Diamonds изготавливаются из золота 585 пробы — белого, жёлтого или розового. Выбор цвета золота обсуждается при оформлении заказа.",
  },
  {
    q: "Как выбрать размер кольца?",
    a: "Вы можете выбрать размер из доступных при оформлении заказа. Если вы не знаете свой размер, свяжитесь с нами — мы поможем определить его. Также после покупки кольцо можно скорректировать в ювелирной мастерской (в пределах одного размера).",
  },
  {
    q: "Есть ли сертификат на бриллиант?",
    a: "Да, каждое изделие XO Diamonds сопровождается сертификатом, подтверждающим характеристики бриллианта — вес в каратах, цвет, чистоту и тип огранки.",
  },
  {
    q: "Как ухаживать за украшениями?",
    a: "Мы рекомендуем снимать украшения перед сном, занятиями спортом и контактом с бытовой химией. Для очистки используйте мягкую ткань или тёплый мыльный раствор с мягкой щёткой, затем протрите насухо. Раз в год желательна профессиональная чистка у ювелира.",
  },
  {
    q: "Можно ли заказать индивидуальное изделие?",
    a: "Да, мы принимаем индивидуальные заказы. Свяжитесь с нами через Telegram или форму на сайте, опишите ваши пожелания, и мы подготовим предложение.",
  },
  {
    q: "Как долго изготавливается заказ?",
    a: "Большинство изделий из каталога готовы к отправке в течение 1–3 рабочих дней. Индивидуальные заказы — от 5 до 14 рабочих дней в зависимости от сложности.",
  },
];
---

<Base title={pageTitle} description={pageDescription}>
  <section class="section-sm">
    <div class="container max-w-2xl">
      <span class="gold-line"></span>
      <h1 class="mb-4">FAQ</h1>
      <p class="text-gray-500 mb-12">Часто задаваемые вопросы о CVD бриллиантах и украшениях XO Diamonds.</p>

      <div
        class="space-y-1"
        x-data="{ open: null }"
      >
        {
          faqs.map((faq, i) => (
            <div class="border-b border-gray-100">
              <button
                class="w-full flex items-center justify-between py-5 text-left hover:text-black transition-colors"
                :class="{ 'text-black': open === {i}, 'text-gray-700': open !== {i} }"
                @click={`open = open === ${i} ? null : ${i}`}
              >
                <span class="pr-4 font-medium">{faq.q}</span>
                <span class="flex-shrink-0 text-xl leading-none transition-transform duration-300" :class="{ 'rotate-45': open === {i} }">+</span>
              </button>
              <div
                class="overflow-hidden transition-all duration-300"
                :class="open === {i} ? 'max-h-96 pb-5' : 'max-h-0'"
              >
                <p class="text-gray-600 text-sm leading-relaxed">{faq.a}</p>
              </div>
            </div>
          ))
        }
      </div>

      <div class="mt-12 pt-8 border-t border-gray-100 text-center">
        <p class="text-gray-400 text-sm mb-4">Не нашли ответ?</p>
        <a href="/contacts/" class="btn btn-outline">Задайте вопрос</a>
      </div>
    </div>
  </section>
</Base>
