---
// XO Diamonds – Base Layout
// All pages inherit this luxury minimal shell.
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

export interface Props {
  title: string;
  description: string;
  ogImage?: string | undefined;
  noIndex?: boolean | undefined;
}

const {
  title,
  description,
  ogImage = "/images/og-default.jpg",
  noIndex = false,
} = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — XO Diamonds</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={`${title} — XO Diamonds`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    {
      noIndex && (
        <meta name="robots" content="noindex, nofollow" />
      )
    }

    <!-- Fonts: Playfair Display (serif) + Inter (sans) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&display=swap"
      rel="stylesheet"
    />

    <!-- Alpine.js: client-side interactivity (cart, filters, reveal) -->
    <script
      is:inline
      src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"
      defer
    ></script>

    <!-- Global inline script -->
    <script is:inline>
      document.documentElement.style.setProperty(
        "--vh",
        `${window.innerHeight * 0.01}px`,
      );
    </script>
  </head>
  <body class="flex flex-col min-h-screen">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
